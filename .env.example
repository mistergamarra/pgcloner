# Copy to .env and fill in the values you need. Every var here can also be
# passed as a CLI flag instead (flags take precedence) — see
# `pgcloner --help`.

# Teleport proxy address, e.g. teleport.example.com.
# Required for `login`; no default.
PGCLONER_TELEPORT__CLUSTER=

# Local port `tsh proxy db` tunnels through.
# Default: 10007
PGCLONER_TELEPORT__DB_PORT=10007

# Comma-separated DB usernames offered in `dump`'s user-selection step.
# Leave unset to type one in freely instead.
PGCLONER_TELEPORT__DB_USERS=admin,readonly

# Database used to list other databases when your Teleport role allows any.
# Default: postgres
PGCLONER_TELEPORT__BOOTSTRAP_DB=postgres

# Container CLI used for `restore` containers: docker or podman.
# Default: docker
PGCLONER_RESTORE__CONTAINER_CMD=docker

# Container image used for `restore` containers. Any postgres or
# postgis/postgis tag works.
# Default: postgres:16
PGCLONER_RESTORE__PG_IMAGE=postgres:16

# Superuser password set on `restore` containers.
# Default: postgres
PGCLONER_RESTORE__PG_PASSWORD=postgres
